# Agregar/ajustar en backend/.env
# No dejes que el formulario público use DEFAULT_TENANT_ID en producción.
PUBLIC_FORM_ALLOW_QUERY_TENANT=false
PUBLIC_FORM_ALLOW_DEFAULT_TENANT=false

# Permití los subdominios públicos del formulario.
# Cambiá el dominio si usás otro.
ALLOWED_ORIGIN_WILDCARDS=https://*.lerna.3devsnet.com

# Remitente de emails de confirmación.
# Debe ser una cuenta existente/autorizada en el hosting para que mail() no falle.
MAIL_FROM_EMAIL=lerna@3devsnet.com
MAIL_FROM_NAME=Soporte Lerna
